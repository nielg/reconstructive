---
import AanbodCard from "@components/AanbodCard.astro";
import constructImg from "@assets/imgs/constructImg.jpg";
import grassPathImg from "@assets/imgs/grass-path.jpg";
import mountainPathImg from "@assets/imgs/mountain-path.jpg";
import AanbodDetails from "./AanbodDetails.astro";
import { getLangFromUrl, useTranslations } from "@src/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="aanbod-container">
  <div class="aanbod-section">
    <div class="card-wrapper" data-content="construct" id="construct">
      <AanbodCard
        title={t("aanbod.cards.construct.title")}
        text={t("aanbod.cards.construct.text")}
        link="#"
        alt={t("aanbod.cards.construct.alt")}
        img={constructImg}
      />
    </div>
    <div class="details text-gray text-margin" data-content="construct">
      <AanbodDetails
        title={t("aanbod.details.construct.title")}
        text={[
          t("aanbod.details.construct.text1"),
          t("aanbod.details.construct.text2"),
          t("aanbod.details.construct.text3"),
          t("aanbod.details.construct.text4"),
          t("aanbod.details.construct.text5"),
        ]}
        li={[
          t("aanbod.details.construct.li1"),
          t("aanbod.details.construct.li2"),
          t("aanbod.details.construct.li3"),
          t("aanbod.details.construct.li4"),
        ]}
        wie={t("aanbod.details.construct.wie")}
        waar={t("aanbod.details.construct.waar")}
        wanneer={t("aanbod.details.construct.wanneer")}
        prijs={t("aanbod.details.construct.prijs")}
        aantal_deelnemers={t("aanbod.details.construct.aantalDeelnemers")}
      />
    </div>
  </div>

  <div class="aanbod-section">
    <div class="card-wrapper" data-content="reconstructive" id="reconstructive">
      <AanbodCard
        title={t("aanbod.cards.reconstructive.title")}
        text={t("aanbod.cards.reconstructive.text")}
        link="#"
        alt={t("aanbod.cards.reconstructive.alt")}
        img={grassPathImg}
      />
    </div>
    <div class="details text-gray text-margin" data-content="reconstructive">
      <AanbodDetails
        title={t("aanbod.details.reconstructive.title")}
        text={[
          t("aanbod.details.reconstructive.text1"),
          t("aanbod.details.reconstructive.text2"),
          t("aanbod.details.reconstructive.text3"),
          t("aanbod.details.reconstructive.text4"),
          t("aanbod.details.reconstructive.text5"),
          t("aanbod.details.reconstructive.text6"),
        ]}
        li={[
          t("aanbod.details.reconstructive.li1"),
          t("aanbod.details.reconstructive.li2"),
          t("aanbod.details.reconstructive.li3"),
          t("aanbod.details.reconstructive.li4"),
          t("aanbod.details.reconstructive.li5"),
        ]}
        wie={t("aanbod.details.reconstructive.wie")}
        waar={t("aanbod.details.reconstructive.waar")}
        wanneer={t("aanbod.details.reconstructive.wanneer")}
        prijs={t("aanbod.details.reconstructive.prijs")}
        aantal_deelnemers={t("aanbod.details.reconstructive.aantalDeelnemers")}
      />
    </div>
  </div>

  <div class="aanbod-section">
    <div class="card-wrapper" data-content="gold" id="gold">
      <AanbodCard
        title={t("aanbod.cards.gold.title")}
        text={t("aanbod.cards.gold.text")}
        link="#"
        alt={t("aanbod.cards.gold.alt")}
        img={mountainPathImg}
      />
    </div>
    <div class="details text-gray text-margin" data-content="gold">
      <AanbodDetails
        title={t("aanbod.details.gold.title")}
        text={[
          t("aanbod.details.gold.text1"),
          t("aanbod.details.gold.text2"),
          t("aanbod.details.gold.text3"),
          t("aanbod.details.gold.text4"),
          t("aanbod.details.gold.text5"),
        ]}
        li={[
          t("aanbod.details.gold.li1"),
          t("aanbod.details.gold.li2"),
          t("aanbod.details.gold.li3"),
          t("aanbod.details.gold.li4"),
        ]}
        wie={t("aanbod.details.gold.wie")}
        waar={t("aanbod.details.gold.waar")}
        wanneer={t("aanbod.details.gold.wanneer")}
        prijs={t("aanbod.details.gold.prijs")}
        aantal_deelnemers={t("aanbod.details.gold.aantalDeelnemers")}
      />
    </div>
  </div>
</div>

<script>
  const init = () => {
    const cardWrappers =
      document.querySelectorAll<HTMLElement>(".card-wrapper");
    const details = document.querySelectorAll<HTMLElement>(".details");

    // 1. Check de URL hash bij het laden van de pagina
    const hash = window.location.hash.replace("#", "");
    if (hash) {
      const cardWithContent = document.getElementById(hash);

      if (cardWithContent) {
        cardWithContent.classList.add("active");

        details.forEach((detail) => {
          detail.classList.remove("show");
          if (detail.dataset.content === hash) {
            detail.classList.add("show");
          }
        });
      }
    }

    // 2. Click handlers voor de kaarten
    if (cardWrappers.length > 0) {
      cardWrappers.forEach((cardWrapper) => {
        cardWrapper.addEventListener("click", (event) => {
          event.preventDefault();
          const content = cardWrapper.dataset.content;

          if (!content) return;

          window.location.hash = content;

          cardWrappers.forEach((cw) => {
            if (cw.dataset.content === content) {
              cw.classList.add("active");
            } else {
              cw.classList.remove("active");
            }
          });

          details.forEach((detail) => {
            detail.classList.remove("show");
            if (detail.dataset.content === content) {
              detail.classList.add("show");
              detail.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            }
          });
        });
      });
    }
  };

  document.addEventListener("astro:page-load", init);
</script>

<style>
  /* --- DESKTOP LAYOUT --- */
  .aanbod-container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    margin: 3rem;
  }

  .aanbod-section {
    display: contents;
  }

  .card-wrapper {
    cursor: pointer;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.4s ease;
  }
  .card-wrapper:hover {
    transform: translateY(-8px);
  }

  .card-wrapper.active {
    transform: translateY(80px);
    opacity: 1 !important;
  }

  .aanbod-container:has(.card-wrapper.active) .card-wrapper:not(.active) {
    opacity: 0.6;
  }

  /* Details op desktop */
  .details {
    grid-template-columns: 1fr 1fr;
    column-gap: 3rem;
    display: none;
    scroll-margin-top: 300px;
    grid-column: 1 / span 3;
  }

  .details.show {
    display: grid;
  }

  .details.show > * {
    opacity: 0;
    animation: detailsFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .details.show > *:nth-child(1) {
    animation-delay: 0.05s;
  }
  .details.show > *:nth-child(2) {
    animation-delay: 0.18s;
  }

  @keyframes detailsFadeIn {
    0% {
      opacity: 0;
      transform: translateY(15px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 800px) {
    .aanbod-container {
      display: flex;
      flex-direction: column;
      margin: 1.5rem;
      gap: 1.5rem;
    }

    .aanbod-section {
      display: block;
    }

    .card-wrapper {
      margin-bottom: 1rem;
    }

    .card-wrapper.active {
      transform: none; /* Geen opmerkelijke desktop-verschuivingen op mobiel */
    }

    /* Details tonen in 1 kolom onder de actieve kaart */
    .details.show {
      display: block;
      grid-template-columns: 1fr;
      padding: 1.5rem 0;
      margin-bottom: 2rem;
      border-radius: 8px;
    }

    .details {
      scroll-margin-top: 0;
    }
  }
</style>
