---
import "@src/styles/global.css";
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from "@src/i18n/utils";
import LanguagePicker from "./LanguagePicker.astro";
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);
---

<footer class="bg-dark text-white">
  <div class="row">
    <h3>Reconstructive.be</h3>
    <p>Elke Busschots: + 32 475 46 39</p>
    <p>Bram Geysen: +32 473 52 30 94</p>
    <LanguagePicker place="footer" />
  </div>
  <div class="col3">
    <div class="navigation">
      <h4>Navigation</h4>
      <p><a href={translatePath("/")}>home</a></p>
      <p><a href={translatePath("/aanpak")}>{t("nav.aanpak")}</a></p>
      <p>
        <a href={translatePath("/aanbod")}>{t("nav.aanbod")}</a>
      </p>
      <p>
        <a href={translatePath("/impressies")}>{t("nav.impressies")}</a>
      </p>
      <p><a href={translatePath("/about")}>{t("nav.about")}</a></p>
      <p><a href={translatePath("/posts")}>blog</a></p>
    </div>
  </div>
  <p class="text-align-center">
    &copy; 2026 Reconstructive.be. All Rights Reserved
  </p>
</footer>

<style>
  footer {
    color: #b7aaaa;
    padding-bottom: 1rem;
  }

  .row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    padding: 0 1em;
  }

  .col3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 1rem;
    margin: 1rem;
  }
  .navigation {
    display: flex;
    flex-direction: row;
    white-space: nowrap;
    column-gap: 2rem;
  }

  p,
  li,
  .normal-font-size {
    font-size: 1rem;
  }

  h3 {
    font-size: 1.5rem;
  }

  h4 {
    font-size: 1.25rem;
    margin: 0.5rem 0;
  }

  @media (max-width: 750px) {
    .row {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .col3 {
      grid-template-columns: 1fr;
      text-align: center;
      row-gap: 2rem;
    }

    .col3 ul {
      padding-left: 0;
    }
  }
</style>
