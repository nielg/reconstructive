---
import type { Kalender } from "@src/types";

type Props = {
  kalenderData: Kalender;
};

const { kalenderData } = Astro.props;
---

<div class="container bg-beige text-gray">
  <div class="header">
    <hr class="yellow-line" />
    <h3 class="text-green text-align-center">{kalenderData.title}</h3>
    <hr class="yellow-line" />
  </div>
  <div>
    <h4 class="text-green text-align-center">{kalenderData.type}</h4>
    <p>
      <strong>Datum: </strong>{
        kalenderData.overnachting
          ? `Met overnachting`
          : `Zonder overnacthing telkens van 10uur - 17uur`
      }
    </p>
    <p><strong>Prijs:</strong> {kalenderData.prijs}</p>
    <p><strong>Voor:</strong> {kalenderData.voorWie}</p>
    <p><strong>Locatie:</strong> {kalenderData.locatie}</p>
    <p><strong>Taal:</strong> {kalenderData.taal}</p>
    {
      kalenderData.aantalDeelnemers && (
        <p>
          <strong>Max aantal deelnemers:</strong>
          {kalenderData.aantalDeelnemers}
        </p>
      )
    }
    <a href="/">
      <button class="green-btn">lees meer</button>
    </a>
  </div>
</div>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 2px solid #dec15b;
    border-radius: 10px;
    padding: 0.5rem 1rem;
    font-size: xx-small;
  }

  .header {
    width: 100%;
  }

  .container h3 {
    font-size: 1.7rem;
    margin: 10px 0;
  }
</style>
