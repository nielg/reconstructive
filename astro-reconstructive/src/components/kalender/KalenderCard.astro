---
import { getLangFromUrl, useTranslatedPath } from "@src/i18n/utils";
import type { Kalender } from "@src/types";

type Props = {
  kalenderData: Kalender;
};
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const { kalenderData } = Astro.props;

let anchor = "";

switch (kalenderData.type) {
  case "Voorbij je construct":
    anchor = "/aanbod#construct";
  case "Find your gold":
    anchor = "/aanbod#gold";
    break;
  case "Reconstructive":
    anchor = "/aanbod#reconstructive";
    break;
  default:
    anchor = "/aanbod";
}

const link = translatePath(anchor);
---

<div class="container bg-beige text-gray">
  <div class="header">
    <hr class="yellow-line" />
    <h3 class="text-green text-align-center">{kalenderData.title}</h3>
    <hr class="yellow-line" />
  </div>
  <div class="body">
    <h4 class="text-green text-align-center">{kalenderData.type}</h4>
    <p>
      <strong>Datum: </strong>{
        kalenderData.overnachting
          ? `Met overnachting`
          : `Zonder overnacthing telkens van 10uur - 17uur`
      }
    </p>
    <p><strong>Prijs:</strong> {kalenderData.prijs}</p>
    <p><strong>Voor:</strong> {kalenderData.voorWie}</p>
    <p><strong>Locatie:</strong> {kalenderData.locatie}</p>
    <p><strong>Taal:</strong> {kalenderData.taal}</p>
    {
      kalenderData.aantalDeelnemers && (
        <p>
          <strong>Max aantal deelnemers:</strong>
          {kalenderData.aantalDeelnemers}
        </p>
      )
    }
    <a href={link} class="btn-link">
      <button class="green-btn">lees meer</button>
    </a>
  </div>
</div>

<style>
  .container {
    display: flex;
    flex-direction: column;
    border: 2px solid #dec15b;
    border-radius: 10px;
    font-size: xx-small;
    position: relative;
    padding: 2rem 1rem 3rem 1rem;
  }

  .header {
    width: 100%;
  }

  .container h3 {
    font-size: 1.7rem;
    margin: 10px 0;
  }

  .btn-link {
    position: absolute;
    bottom: 10px;
    left: 10px;
  }
</style>
