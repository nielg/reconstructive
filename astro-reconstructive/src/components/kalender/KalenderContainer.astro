---
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";
import KalenderCard from "./KalenderCard.astro";
import type { Kalender } from "@src/types";

const POSTS_QUERY = `*[
  _type == "kalender"
] | order(datum asc){_id, title, datum, locatie, prijs, taal, aantalDeelnemers, voorWie, overnachting}`;

const posts = await sanityClient.fetch<SanityDocument[]>(POSTS_QUERY);

const kalenderItems: Kalender[] = posts as unknown as Kalender[];
---

<h2 class="text-align-center">Kalender</h2>
<div class="container">
  {kalenderItems.map((item) => <KalenderCard kalenderData={item} />)}
</div>

<style>
  .container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    padding: 1rem;
    width: 100%;
    box-sizing: border-box;
  }

  @media (max-width: 440px) {
    .container {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 12px;
    }
  }
</style>
