---
import { Image } from "astro:assets";
import Layout from "@src/layouts/Layout.astro";
import SplitGrid from "@components/SplitGrid.astro"; // <-- Geïmporteerd
import {
  getStaticPaths,
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@src/i18n/utils";
import woodenPeopleImg from "@assets/imgs/wooden-mans.jpg";
import painBreaksWhatImg from "@assets/imgs/Pain_breaks_what.jpg";
import sandAngelImg from "@assets/imgs/sand-angel.jpg";
import whiteFlower from "@assets/imgs/white-flower.jpg";
import sunflower from "@assets/imgs/zonnebloem.png";

export { getStaticPaths };
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title="aanpak">
  <section class="bg-beige text-gray text-align-justify">
    <div class="container small-text-margin">
      <h1 class="text-green text-align-center">
        {t("aanpak.hero.title")}
      </h1>
      <p>
        {t("aanpak.hero.text1")}
      </p>
      <p>
        {t("aanpak.hero.text2")}
      </p>
      <p>
        {t("aanpak.hero.text3")}
      </p>
    </div>
  </section>
  <section class="kern bg-green text-white center">
    <h2>{t("aanpak.kern.title")}</h2>
    <h2>{t("aanpak.kern.subtitle")}</h2>
  </section>

  <section class="no-padding">
    <SplitGrid>
      <!-- 1. Natuur & energie (Afbeelding) -->
      <div class="img-wrapper first">
        <Image
          class="img"
          alt={t("aanpak.point1.imgAlt")}
          width={600}
          height={600}
          src={sunflower}
        />
      </div>

      <!-- 1. Natuur & energie (Tekst) -->
      <div class="text-wrapper bg-beige second">
        <div class="text-gray text">
          <p>
            <strong>{t("aanpak.point1.title")}</strong>{
              t("aanpak.point1.text1")
            }
          </p>
          <p>
            {t("aanpak.point1.text2")}
          </p>
          <p set:html={t("aanpak.point1.text3")} />
          <p set:html={t("aanpak.point1.text4")} />
        </div>
      </div>

      <!-- 2. Overleven & identiteit (Tekst) -->
      <div class="text-wrapper bg-green fourth">
        <div class="text-white text margin-left">
          <p>
            <strong>{t("aanpak.point2.title")}</strong>{
              t("aanpak.point2.text1")
            }
          </p>
          <p>
            {t("aanpak.point2.text2")}
          </p>
          <p>
            {t("aanpak.point2.text3")}
          </p>
        </div>
      </div>

      <!-- 2. Overleven & identiteit (Afbeelding) -->
      <div class="img-wrapper third">
        <Image
          class="img"
          alt={t("aanpak.point2.imgAlt")}
          width={500}
          height={500}
          src={woodenPeopleImg}
        />
      </div>

      <!-- 3. Doorbreken & bewustwording (Afbeelding) -->
      <div class="img-wrapper fifth">
        <Image
          class="img"
          alt={t("aanpak.point3.imgAlt")}
          width={500}
          height={500}
          src={painBreaksWhatImg}
        />
      </div>

      <!-- 3. Doorbreken & bewustwording (Tekst) -->
      <div class="text-wrapper bg-beige sixth">
        <div class="text-gray text">
          <p>
            <strong>{t("aanpak.point3.title")}</strong>{
              t("aanpak.point3.text1")
            }
          </p>
          <p>
            {t("aanpak.point3.text2")}
          </p>
          <p>
            {t("aanpak.point3.text3")}
          </p>
          <p>
            {t("aanpak.point3.text4")}
          </p>
          <p>
            {t("aanpak.point3.text5")}
          </p>
        </div>
      </div>

      <!-- 4. Belichaming & creatie (Tekst) -->
      <div class="text-wrapper bg-green eight">
        <div class="text-white text margin-left">
          <p>
            <strong>{t("aanpak.point4.title")}</strong>{
              t("aanpak.point4.text1")
            }
          </p>
          <p>
            {t("aanpak.point4.text2")}
          </p>
          <p>
            {t("aanpak.point4.text3")}
          </p>
          <p>
            {t("aanpak.point4.text4")}
          </p>
          <p>
            {t("aanpak.point4.text5")}
          </p>
        </div>
      </div>

      <!-- 4. Belichaming & creatie (Afbeelding) -->
      <div class="img-wrapper seventh">
        <Image
          class="img"
          alt={t("aanpak.point4.imgAlt")}
          width={500}
          height={500}
          src={sandAngelImg}
        />
      </div>

      <!-- 5. Heelheid & integratie (Afbeelding) -->
      <div class="img-wrapper neight">
        <Image
          class="img"
          alt={t("aanpak.point5.imgAlt")}
          width={500}
          height={500}
          src={whiteFlower}
        />
      </div>

      <!-- 5. Heelheid & integratie (Tekst) -->
      <div class="text-wrapper bg-beige tenth">
        <div class="bg-beige text-gray text">
          <p>
            <strong>{t("aanpak.point5.title")}</strong>{
              t("aanpak.point5.text1")
            }
          </p>
          <p>
            {t("aanpak.point5.text2")}
          </p>
          <p>
            {t("aanpak.point5.text3")}
          </p>
        </div>
      </div>
    </SplitGrid>
  </section>

  <section class="bg-green text-white center">
    <h2>{t("aanpak.journey.title")}</h2>
  </section>
  <section class="bg-beige text-gray">
    <div class="small-text-margin">
      <h2 class="center text-green">
        {t("aanpak.ready.title")}
      </h2>
      <p>
        {t("aanpak.ready.body1")}
      </p>
      <p>
        {t("aanpak.ready.body2")}
      </p>
      <a href={translatePath("/aanbod")} class="center">
        <button class="green-btn big-btn p3">
          {t("aanpak.ready.button")}
        </button>
      </a>
    </div>
  </section>
</Layout>

<style>
  .kern h2 {
    margin: 1rem;
  }
</style>
