---
import AanbodCard from "@components/AanbodCard.astro";
import constructImg from "@assets/imgs/constructImg.jpg";
import grassPathImg from "@assets/imgs/grass-path.jpg";
import mountainPathImg from "@assets/imgs/mountain-path.jpg";
import AanbodDetails from "./AanbodDetails.astro";
---

<div class="grid">
  <div class="aanbodCardContainer">
    <div class="card-wrapper" data-content="construct">
      <AanbodCard
        title="Voorbij je construct (1 dag)"
        text="Stap één dag buiten je vertrouwde patronen en ontdek hoeveel ruimte er ontstaat wanneer je je construct loslaat."
        link="#"
        alt="Foto van een plein met een bloem in het midden"
        img={constructImg}
      />
    </div>
    <div class="card-wrapper" data-content="reconstructive">
      <AanbodCard
        title="Reconstructive (2 dagen)"
        text="Ervaar de transformerend kracht van Reconstructive en kom dichter bij je intuïtie, je vrijheid en je kern."
        link="#"
        alt="Foto van een houte pad door het hoge grass"
        img={grassPathImg}
      />
    </div>
    <div class="card-wrapper" data-content="gold">
      <AanbodCard
        title="Find your gold (6 dagen)"
        text="Ga op een diepgaande reis door natuur en lichaam, en keer terug naar de essentie van wie jij werkelijk bent"
        link="#"
        alt="Foto van een houten pad door een dor veld met bergen in de achtergrond"
        img={mountainPathImg}
      />
    </div>
  </div>
  <div class="details text-gray text-margin" data-content="construct">
    <AanbodDetails
      title="Een ontmoeting"
      text={[
        " Een eerste ontmoeting met je essentie en met de reconstructive methode.",
        "Voor wie wilt proeven van wat er leeft voorbij je patronen",
        "Merk jij ook dat sommigen vrijer leven dan jij? Dat als jij iets wil veranderen, er meteen een stem in jouw hoofd zegt, 'ja maar, dat kan niet want...' Die stemmetjes bepalen mee hoe groot jouw vrijheid aanvoelt.",
        "Tijdens deze initiatiedag stap je uit je vertrouwde kaders. Via belevings-oefeningen en de wijsheid van de natuur word je uitgenodigd om buiten je construct te stappen. Het is alsof je een raam opent dat lang dicht zat. Er komt licht binnen. Ruimte. Nieuwsgierigheid.",
        "De natuur vindt altijd een weg ook in complexe omstandigheden. En precies dat herinnert jou eraan dat ook jij kunt bewegen, verschuiven, openen.",
      ]}
      li={[
        "Ruimer perspectief op je eigen patronen",
        "Een eerste ervaring van ruimte en vrijheid",
        "Meer bewustzijn over wat jou stuurt",
        "Nieuwsgierigheid als startpunt voor groei",
      ]}
      wie="Voor nieuwsgierigen die willen proeven, hun blik willen verruimen en inzicht willen krijgen in hun patronen"
      waar="Leuven/Heverlee"
      wanneer="2026"
      prijs="125 euro excl BTW (incl. koffie, thee, versnapperingen en lunch)"
      aantal_deelnemers="12"
    />
  </div>
  <div class="details text-gray text-margin" data-content="reconstructive">
    <AanbodDetails
      title="Een uitndoging"
      text={[
        "een uitnodiging om dichter bij jezelf te komen.",
        "Soms voel je dat er nog iets in de weg zit. Iets wat niet via het hoofd loskomt, maar via het lichaam wil gezien worden.",
        "Vaak zijn het diepgewortelde patronen, oude verhalen, ingehouden emoties en overlevingsstrategieën die ons onbewust ervan weerhouden om ons potentieel ten volle te leven. Door ermee te werken in het lichaam komt er beweging, helderheid en richting.",
        "Via Reconstructive wordt het denken opzijgezet. Wat overblijft is het lichaam en wat het je te vertellen heeft.",
        "We werken in kleine groepjes, zonder taal. We bouwen samen een energetisch veld waaruit beweging ontstaat. De groep is een spiegelend veld: wat je bij anderen ziet, raakt iets in jou. Wat jij laat zien, opent iets bij hen.",
        "Reconstructive is geen therapie, maar een uitnodiging om je over te geven aan wat zich in jou wil tonen. Zonder verhaal. Zonder analyse. Alleen een directe ontmoeting met jezelf en je volle potentieel.",
      ]}
      li={[
        "Ruimer perspectief op je eigen patronen",
        "Meer vrijheid",
        "Nieuwe inzichten",
        "Doorbraak in patronen die tot nu toe bleven vastzitten",
        "Een ervaring die een blijvende indruk nalaat",
      ]}
      wie="Voor wie voelt dat er iets vastzit en klaar is om dieper te gaan"
      waar="Leuven"
      wanneer="25 - 26 juli 2026 (9-16u), De volgende 2-daagse gaat door op 17 - 18 oktober 2026 (9-16u)"
      prijs="375 excl BTW (incl. Koffie, thee, versnapperingen en lunch)"
      aantal_deelnemers="8"
    />
  </div>
  <div class="details text-gray text-margin" data-content="gold">
    <AanbodDetails
      title="Een thuiskomen"
      text={[
        "Een thuiskomen bij jezelf.",
        "Deze retreat is een innerlijke tocht waarbij we laag na laag dichterbij jouw blauwdruk komen, zodat zichtbaar wordt wie je altijd al was.",
        "Elke dag trekken we de natuur in. Ze spiegelt je zonder oordeel: waar je nog vasthoudt, waar je mag verzachten, waar je mag openen. De natuur laat zien wat je lichaam al wist, maar wat je hoofd misschien nog niet durfde te erkennen.",
        "Reconstructive maakt zichtbaar wat je onderweg tegenkomt: oude patronen, beschermingslagen, ingehouden emoties. Door ermee te werken in het lichaam komt er beweging, helderheid en richting. Je voelt hoe je dichter bij je blauwdruk komt dat stille, diepe weten van wie jij in essentie bent.",
        "De groep wordt een bedding. Je hoeft het niet alleen te doen, maar je maakt wel je eigen innerlijke reis.",
      ]}
      li={[
        "Meer helderheid",
        "belichaming",
        "rust",
        "stevig contact met je kern",
      ]}
      wie="een reset wil, oude lagen wil loslaten en zijn/haar/hun blauwdruk wil herontdekken"
      waar="Zuid - Noorwegen "
      wanneer="5 - 12 september 2026"
      prijs="1750 euro (excl BTW) (enkel vervoer heen en terug is niet inbegrepen: auto of vlucht naar Kristiansand)"
      aantal_deelnemers="8"
    />

    <script>
      const init = () => {
        const cardWrappers =
          document.querySelectorAll<HTMLElement>(".card-wrapper");

        const details = document.querySelectorAll<HTMLElement>(".details");

        if (cardWrappers.length > 0) {
          cardWrappers.forEach((cardWrapper) => {
            cardWrapper.addEventListener("click", (event) => {
              event.preventDefault();
              const content = cardWrapper.dataset.content;

              console.log("Geklikt op:", content);

              details.forEach((detail) => {
                detail.classList.remove("show");

                if (detail.dataset.content == content) {
                  detail.classList.add("show");
                }
              });
            });
          });
        }
      };

      document.addEventListener("DOMContentLoaded", init);
    </script>

    <style>
      .aanbodCardContainer {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-evenly;
        gap: 2rem;
        margin: 3rem;
      }

      .details {
        grid-template-columns: 1fr 1fr;
        column-gap: 3rem;
        display: none;
      }

      .details.show {
        display: grid;
      }
    </style>
  </div>
</div>
