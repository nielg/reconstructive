---
import { Image } from "astro:assets";

interface Props {
  title: string;
  text: string;
  img: string;
  alt: string;
  link: string;
}

const { title, text, img, alt, link } = Astro.props;
---

<div class="container text-gray">
  <!-- <Image alt={alt} src={img} width={200} height={200} /> -->
  <h3 class="text-green">{title}</h3>
  <p>{text}</p>
  <a href={link} class="center">
    <button class="green-btn"> Lees meer </button>
  </a>
</div>

<style>
  .container {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
</style>
