---
import { Image } from "astro:assets";
import logo from "@assets/imgs/logo.jpg";
import LanguagePicker from "./LanguagePicker.astro";
---

<header class="bg-white">
  <LanguagePicker place="header" />
  <Image src={logo} alt="Reconstructive logo" width={300} height={300} />
  <h2 class="text-green center">Reconstructive.be</h2>
</header>

<style>
  header {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding-top: 3rem;
  }
  h2 {
    color: var(--reconstructive-green);
    font-size: 3.5rem;
    margin-top: 0;
  }

  @media (max-width: 800px) {
    header {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    h2 {
      font-size: 2.5rem;
    }
  }
</style>
