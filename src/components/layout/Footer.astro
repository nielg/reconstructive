---
import "@src/styles/global.css";
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from "@src/i18n/utils";
import LanguagePicker from "./LanguagePicker.astro";
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);
---

<footer class="bg-dark text-white">
  <div class="row">
    <h3>Reconstructive.be</h3>
    <LanguagePicker place="footer" />
  </div>
  <div class="col3">
    <div>
      <h4>Navigation</h4>
      <ul class="none-list">
        <li><a href={translatePath("/")}>home</a></li>
        <li><a href={translatePath("/aanpak")}>{t("nav.aanpak")}</a></li>
        <li>
          <a href={translatePath("/aanbod")}>{t("nav.aanbod")}</a>
        </li>
        <li>
          <a href={translatePath("/impressies")}>{t("nav.impressies")}</a>
        </li>
        <li><a href={translatePath("/about")}>{t("nav.about")}</a></li>
        <li><a href={translatePath("/posts")}>blog</a></li>
      </ul>
    </div>
    <div>
      <h4>Reconstructive.be</h4>
      <p>Bram Geysen: +32 473 52 30 94</p>
      <p>Elke Busschots: + 32 475 46 39</p>
      <a href="mailto:info@reconstructive.be"><p>info@reconstructive.be</p></a>
    </div>
    <div class="credits">
      <h4>Credits</h4>
      <p>
        {t("footer.website")}
        <a href="mailto:nielgeysen@gmail.com">nielgeysen@gmail.com</a>
      </p>
    </div>
  </div>
  <p class="text-align-center">
    &copy; 2026 Reconstructive.be. All Rights Reserved
  </p>
</footer>

<style>
  footer {
    color: #b7aaaa;
    padding-bottom: 1rem;
  }

  .row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    padding: 0 1em;
  }

  .col3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 1rem;
    margin: 1rem;
  }
  .ul {
    list-style-type: none;
  }

  p {
    margin: 0.5rem;
  }

  p,
  li,
  .normal-font-size {
    font-size: 0.7rem;
  }

  h3 {
    font-size: 1.5rem;
  }

  h4 {
    font-size: 1.25rem;
    margin: 0.5rem 0;
  }

  @media (max-width: 750px) {
    .col3 {
      grid-template-columns: 1fr;
    }
  }
</style>
