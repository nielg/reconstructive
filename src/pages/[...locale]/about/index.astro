---
import Layout from "@src/layouts/Layout.astro";
import { Image } from "astro:assets";
import SplitGrid from "@components/SplitGrid.astro";
import elkeProfiel from "@assets/imgs/elke-profile.jpg";
import bramProfiel from "@assets/imgs/bram-profile.png";
import groupPhotoImg from "@assets/imgs/group-foto.jpg";
import rihsLogo from "@assets/imgs/RIIHS-logo.png";

import {
  getStaticPaths,
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@src/i18n/utils";

export { getStaticPaths };
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout>
  <section class="bg-green text-white text-align-center">
    <div class="small-text-margin">
      <h1>Ontdek Reconstructive: Jouw reis naar authenticiteit</h1>
      <p>
        Bij Reconstructive begeleiden we je naar leven vanuit je kern —
        authentiek, intuïtief en vrij. Ontdek een nieuwe manier van kijken en
        groeien. Ben je klaar om je ware zelf te onthullen?
      </p>
    </div>
  </section>

  <section class="no-padding">
    <div class="bg-yellow yellow-section text-align-center">
      <p>
        Reconstructive.be is een samenwerkingen tussen Elke Busschots en Bram
        Geysen die elk hun eigen praktijk hebben en de opleidingen hebben
        gevolgd bij de RHIIS. We werken nauw samen met de international school.
      </p>
    </div>

    <SplitGrid>
      <div class="img-wrapper">
        <Image
          src={elkeProfiel}
          alt="Profiel foto van Elke Busschots"
          width={800}
          height={800}
          class="img elke-img"
        />
      </div>

      <div class="text-wrapper bg-beige">
        <div class="text-gray text">
          <h2 class="text-align-center text-green">Elke</h2>
          <p>
            Al meer dan vijftien jaar begeleid ik mensen die verlangen naar meer
            helderheid, innerlijke stevigheid en een authentieke manier van
            leven en werken.
          </p>
          <p>Mijn kracht ligt in:</p>
          <ul>
            <li>Snel tot de kern komen</li>
            <li>Patronene zichtbaar maken die je zelf niet meer ziet</li>
            <li>Veiligheid creëren waarin je écht kunt zakken</li>
            <li>Helderheid brengen in complexe innerlijke processen</li>
            <li>Je begeleiden naar keuzes die kloppen met jouw essentie</li>
          </ul>
          <p>
            Mijn missie? Mensen en organisaties terugbrengen naar hun kern,
            zodat ze kunnen leven, werken and leiden vanuit wie ze werkelijk
            zijn.
          </p>
          <a
            href="https://www.Cominz.be"
            target="_blank"
            rel="noopener noreferrer"
            class="center"
          >
            <button class="green-btn big-btn">www.Cominz.be</button>
          </a>
        </div>
      </div>

      <div class="text-wrapper bg-beige text-gray fourth">
        <div class="text margin-left">
          <h2 class="center text-green">Bram</h2>
          <p>
            Ik begeleid mensen vanuit de ervaring en het besef dat echte
            transformatie pas begint wanneer het hart durft te smelten.
          </p>
          <p>
            Pas wanneer het hart zich opent, wordt de moed wakker die nodig is
            om te veranderen. Niet de moed van hard vechten of volhouden, maar
            de stille, innerlijke moed die ontstaat wanneer je jezelf toestaat
            om te voelen wat echt klopt.
          </p>
          <p>
            In mijn werk nodig ik anderen uit om diezelfde beweging te maken:
            van hoofd naar hart, van spanning naar ontspanning, van controle
            naar loslaten. Mijn aanpak is geworteld in bewustzijn, adem,
            lichaamswerk en de stille hartsintelligentie die in ons allemaal
            aanwezig is.
          </p>
          <p>Mijn aanpak is zacht, eerlijk en praktisch.</p>
          <a
            href="https://www.mooyo.be"
            target="_blank"
            rel="noopener noreferrer"
            class="center"
          >
            <button class="green-btn big-btn">www.mooyo.be</button>
          </a>
        </div>
      </div>

      <div class="img-wrapper third">
        <Image
          src={bramProfiel}
          alt="Profiel foto van bram geysen"
          width={500}
          height={500}
          class="img"
        />
      </div>
    </SplitGrid>
  </section>
  <section class="bg-green text-white text-align-center">
    <div class="small-text-margin">
      <h2>Onze kernwaarden: Jij bent de expert van je eigen reis</h2>
      <p>
        Wij geloven dat iedereen een geschenk is voor deze wereld, een expert in
        zijn of haar eigen leven, en dat alles wat je nodig hebt al in jezelf
        aanwezig is. Jij zit aan het stuur van je eigen leerproces.
      </p>
      <p>
        Bij Reconstructive helpen we je om je volledige potentieel te ontplooien
        en authentiek te leven.
      </p>
    </div>
  </section>
  <section class="bg-beige text-gray text-align-center">
    <div class="small-text-margin oorsprong">
      <div class="img-wrapper">
        <Image
          alt="groeps foto met Bram Geysen Elke Busschots en Carola Castillo"
          width={500}
          height={500}
          src={groupPhotoImg}
          class="img"
        />
      </div>
      <div class="text">
        <h2 class="text-align-center text-green text-align-center">
          De oorsprong
        </h2>
        <p>
          Carola Castillo is de grondlegster van de methodiek 'Reconstructive'.
          Zij is oprichtster van Reconstructive International Integratie
          Holistic School.
        </p>
        <Image
          alt="Logo International Integration Holistic School"
          width={400}
          height={150}
          src={rihsLogo}
        />
        <a href=""
          ><div class="big-btn green-btn btn">
            <p>Reconstructive International Integrative Holistic School</p>
          </div></a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .yellow-section p {
    margin: 0;
    padding: 3rem;
  }

  .oorsprong {
    display: grid;
    grid-template-columns: 1fr 2fr;
    column-gap: 3rem;
  }

  .oorsprong .img-wrapper {
    overflow: hidden;
    border-radius: 100%;
    aspect-ratio: 1/1;
    width: 100%;
    max-width: 280px;
    margin: auto;
    margin-right: 0;
  }

  .oorsprong .img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .oorsprong p {
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .oorsprong .green-btn {
    margin: 1rem 0;
  }
  .oorsprong .green-btn p {
    margin: 0;
  }
</style>
